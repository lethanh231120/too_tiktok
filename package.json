{
  "name": "tiktok-video-generator",
  "version": "1.0.0",
  "description": "Automated TikTok content generator using Gemini API and Sora",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "react-start": "react-scripts start",
    "dev": "npm run start",
    "react-build": "react-scripts build"
  },
  "dependencies": {
    "@google/genai": "^1.42.0",
    "@google/generative-ai": "^0.3.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.0.0",
    "electron-store": "^8.1.0",
    "fs-extra": "^11.0.0",
    "node-fetch": "^2.7.0",
    "puppeteer": "^21.0.0"
  },
  "devDependencies": {
    "electron": "27.0.0",
    "electron-builder": "24.6.4",
    "electron-is-dev": "^2.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-scripts": "5.0.1"
  },
  "build": {
    "appId": "com.tiktokvidgenerator.app",
    "productName": "TikTok Video Generator",
    "files": [
      "main.js",
      "preload.js",
      "public/**/*",
      "src/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "certificateFile": null
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
